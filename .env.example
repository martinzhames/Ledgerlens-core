# Stellar Horizon API
HORIZON_URL=https://horizon.stellar.org
HORIZON_STREAM_URL=https://horizon.stellar.org

# Network: testnet | mainnet
NETWORK=testnet

# Polling / streaming
POLL_INTERVAL_SECONDS=5
TRADE_HISTORY_LOOKBACK_DAYS=30
CURSOR_PATH=./horizon_cursor.txt

# ── Streaming Feature Store (Redis hot layer + SQLite cold layer) ────
# 
# Replaces the previous full-recompute approach with incremental per-trade
# feature updates. Provides ~3x speedup for large trade volumes.
#
# Redis hot layer: in-memory feature state cache with TTL eviction
# SQLite cold layer: persistent queryable feature history
#
REDIS_URL=redis://localhost:6379/0
# For TLS: rediss://username:password@redis.example.com:6380/0
# Default: redis://localhost:6379/0

# Time-to-live for feature states in Redis hot layer (hours).
# Wallets not trading for this duration are evicted and must be
# rebuilt from cold storage (SQLite) on next access.
# Recommended: 24-48 hours
FEATURE_STORE_TTL_HOURS=48

# Interval (seconds) for periodic flush of hot feature states to
# cold storage (SQLite). Recommended: 300s (5 minutes)
FEATURE_STORE_FLUSH_INTERVAL_SECONDS=300

# Detection engine
BENFORD_MAD_THRESHOLD=0.015
RISK_SCORE_THRESHOLD=70

# Ensemble model weights (need not sum to 1; normalized internally)
ENSEMBLE_WEIGHT_RF=0.25
ENSEMBLE_WEIGHT_XGB=0.50
ENSEMBLE_WEIGHT_LGBM=0.25

# Model artifacts
MODEL_DIR=./models

# Local RiskScore store used by run_pipeline.py and the local API (api/main.py)
LEDGERLENS_DB_PATH=./ledgerlens.db

# LedgerLens-core -> downstream services (other repos in the org)
# ledgerlens-api base URL (consumes scores produced by this pipeline)
LEDGERLENS_API_URL=http://localhost:8000

# ledgerlens-contracts: Soroban contract id for the on-chain risk registry
# Find the deployed contract id in your Soroban RPC explorer or contract deploy log.
LEDGERLENS_SCORE_CONTRACT_ID=

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  CRITICAL SECURITY — NEVER COMMIT THIS VALUE                             ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# Soroban service account used to call submit_score(). Only this account
# is authorised by the contract to write scores on-chain.
# - Keep secret in all environments (dev / staging / production)
# - Never log, never print, never store in version control
# - Rotate immediately if exposed
# - Use a dedicated service account with minimal funding
LEDGERLENS_SERVICE_SECRET_KEY=

# Soroban RPC endpoint (separate from Horizon; used for Soroban contract calls)
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Stellar network passphrase (must match the network the contract is deployed on)
# Testnet: "Test SDF Network ; September 2015"
# Mainnet: "Public Global Stellar Network ; September 2015"
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Circuit breaker for Soroban submissions — stops calling the contract after
# SOROBAN_CIRCUIT_BREAKER_THRESHOLD consecutive failures within a 60s window,
# then auto-resets after SOROBAN_CIRCUIT_RESET_SECONDS.
SOROBAN_CIRCUIT_BREAKER_THRESHOLD=5
SOROBAN_CIRCUIT_RESET_SECONDS=300

# Webhook alert system
# 32-byte base64-encoded AES-256-GCM key for encrypting subscriber HMAC secrets
# Generate with: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
# LEDGERLENS_WEBHOOK_ENCRYPTION_KEY=
# ── Multi-Tenant Namespace Isolation ─────────────────────────────────
# Set LEDGERLENS_MULTI_TENANT_ENABLED=true to activate namespace-based
# data isolation for white-label exchange partner deployments.
# When enabled, every API call must include an X-LedgerLens-Api-Key header
# whose key is registered to a specific namespace_id.
# LEDGERLENS_MULTI_TENANT_ENABLED=false

# CORS — Local API (api/main.py)
# Comma-separated list of allowed browser origins for the local API.
# Default is empty (deny-all). Do NOT set to "*".
#
# Example (dashboard on localhost):
#   LEDGERLENS_CORS_ALLOWED_ORIGINS=http://localhost:3000
#
# Example (staging):
#   LEDGERLENS_CORS_ALLOWED_ORIGINS=https://dashboard.ledgerlens.io,https://staging.ledgerlens.io
#
# SECURITY: never combine a wildcard origin ("*") with allow_credentials=True.
# That combination allows any website to read authenticated responses and is a
# well-known CORS misconfiguration (OWASP A05:2021). The setting rejects "*"
# at startup with a ValueError to make this impossible to misconfigure.
LEDGERLENS_CORS_ALLOWED_ORIGINS=

# ── Federated Learning (optional — only needed for FL participants/server) ────

# Minimum number of participants required before aggregation runs
FEDERATED_MIN_PARTICIPANTS=3

# Differential privacy budget per federated round (Gaussian mechanism)
# Smaller ε = stronger privacy but more noise.  Recommended: 0.5–2.0.
FEDERATED_DP_EPSILON=1.0

# DP delta: probability of ε-DP guarantee failing.  Must be << 1/n_training.
FEDERATED_DP_DELTA=1e-5

# Maximum cumulative privacy budget across all rounds.  When exceeded,
# new rounds are blocked until operators acknowledge via the admin API.
FEDERATED_DP_MAX_EPSILON=10.0

# Maximum L2 norm of a participant gradient update before clipping.
GRADIENT_CLIP_THRESHOLD=10.0

# Cosine similarity threshold below which an update is flagged as a
# potential gradient poisoning attempt and excluded from aggregation.
GRADIENT_OUTLIER_THRESHOLD=0.1

# Standalone federated server network binding
FEDERATED_SERVER_HOST=127.0.0.1
FEDERATED_SERVER_PORT=8001

# ─── Cross-Chain Detection (EVM) ─────────────────────────────────────────────
# JSON-RPC endpoints for each supported EVM chain.
# Use a dedicated API key in production (Infura, Alchemy, QuickNode, etc.).
EVM_RPC_ETHEREUM=https://mainnet.infura.io/v3/YOUR_KEY
EVM_RPC_BASE=https://mainnet.base.org
EVM_RPC_POLYGON=https://polygon-rpc.com
EVM_RPC_ARBITRUM=https://arb1.arbitrum.io/rpc

# Number of blocks to scan back when fetching bridge/swap events.
# 7200 ≈ 24h on Ethereum (12s block time). Adjust per chain.
EVM_LOOKBACK_BLOCKS=7200

# Comma-separated list of EIP-55 checksummed pool addresses to monitor.
# All addresses MUST be in EIP-55 checksum form — Settings validates at startup.
# Example (Uniswap V3 USDC/WETH pool on Ethereum):
#   EVM_POOL_ADDRESSES=0x88e6A0c2dDD26FEEb64F039a2c41296FcB3f5640
EVM_POOL_ADDRESSES=

# ── Causal Inference (DoWhy SCM layer) ────────────────────────────────────────
# Estimation method passed to DoWhy's estimate_effect().
# "backdoor.linear_regression" is fastest and most interpretable.
# For nonlinear effects: "backdoor.econml.dml.DML" (requires econml to be installed).
CAUSAL_ESTIMATION_METHOD=backdoor.linear_regression

# Number of simulated datasets used in DoWhy refutation tests.
# Higher = more reliable p-values; default 100 balances accuracy vs speed.
CAUSAL_REFUTATION_RUNS=100

# Minimum number of scored wallets required before the causal model is fitted.
# Below this threshold the /scores/{wallet}/causal-explanation endpoint returns 503.
CAUSAL_MIN_SAMPLE_SIZE=500
